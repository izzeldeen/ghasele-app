# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends network stats synchronously during install.
# Defaults to false to boost installation speed.
# For more information, see https://github.com/CocoaPods/CocoaPods/issues/4115
install! 'cocoapods', :deterministic_uuids => false

# Flutter Pods
# To learn more about Flutter's Podfile, see https://flutter.dev/to/ios-podfile
# DO NOT MODIFY THIS TARGET DIRECTLY. Use the 'target' block instead.
# For more info, see https://guides.cocoapods.org/syntax/podfile.html

def flutter_root
  # Try environment variable first (standard on build servers like Codemagic)
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']

  # Fallback to Generated.xcconfig for local builds
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1].strip if matches
    end
  end
  
  # Final fallback: try to find it via the 'flutter' command
  flutter_path = `which flutter`.strip
  if !flutter_path.empty?
    return File.expand_path(File.join(File.dirname(File.realdirpath(flutter_path)), '..'))
  end

  raise "FLUTTER_ROOT not found. Please ensure Flutter is in your PATH or set the FLUTTER_ROOT environment variable."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(__FILE__)
end

target 'RunnerTests' do
  inherit! :search_paths
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force ALL pods to at least iOS 14.0 to support google_maps_flutter_ios
      if config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f < 14.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      end
    end
  end
end
